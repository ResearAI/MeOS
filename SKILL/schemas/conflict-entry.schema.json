{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MeOS Conflict Entry",
  "type": "object",
  "required": [
    "id",
    "category",
    "old_claim",
    "new_claim",
    "reason",
    "created_at"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "old_claim": {
      "type": "string"
    },
    "new_claim": {
      "type": "string"
    },
    "reason": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "resolved": {
      "type": "boolean"
    }
  },
  "additionalProperties": true
}
