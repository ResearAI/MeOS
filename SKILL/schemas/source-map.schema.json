  "title": "MeOS Source Map",
  "type": "object",
  "patternProperties": {
    ".*": {
      "type": "object",
      "properties": {
        "source": {
          "type": "string"
        },
        "category": {
          "type": "string"
        },
        "imported_at": {
          "type": "string"
        },
        "sensitive": {
