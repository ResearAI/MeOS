{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MeOS Evidence Entry",
  "type": "object",
  "required": [
    "id",
    "source",
    "category",
    "summary",
    "created_at"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "created_at": {
      "type": "string"
    },
    "sensitive": {
      "type": "boolean"
    },
    "confidence": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    }
  },
  "additionalProperties": true
}
