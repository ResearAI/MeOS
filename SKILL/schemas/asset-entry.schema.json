{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MeOS Asset Entry",
  "type": "object",
  "required": [
    "id",
    "category",
    "title",
    "content",
    "confidence",
    "evidence_count",
    "sources",
    "last_confirmed_at"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "content": {
      "type": "string"
    },
    "confidence": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "evidence_count": {
      "type": "integer",
      "minimum": 0
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "last_confirmed_at": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
